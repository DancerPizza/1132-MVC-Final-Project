@model _1132FinalProject.Models.BookingViewModel
@{
    ViewData["Title"] = "場地租借登記";
}

<div class="booking-page">
    <div class="venue-reference">
        <div class="page-title">場地參考圖</div>
        <div class="reference-image-container">
            <img src="~/Images/Building_2-Booking.png" alt="場地參考圖" />
        </div>
    </div>

    <div class="booking-form">
        @using (Html.BeginForm("BookingSpace", "Booking", FormMethod.Post))
        {
            @Html.AntiForgeryToken()

            <div class="booking-title">@ViewData["Title"]</div>

            <div class="form-group mb-4">
                @Html.LabelFor(m => m.Location)
                @Html.DropDownListFor(m => m.Location,
                         new SelectList(new[] {
            new { Value = "社課專用大空地", Text = "藍色區" },
            new { Value = "地下室電梯前", Text = "粉色區" },
            new { Value = "教室外空地", Text = "紫色區" },
            new { Value = "Room_2011", Text = "2011教室(綠色區)" },
            new { Value = "Room_2010", Text = "2010教室(橘色區)" },
            }, "Value", "Text"), "請選擇場地，紅色區域不可使用　　🔻",
                         new { @class = "form-control custom-dropdown", id = "Location" })
            </div>

            <div class="form-group mb-4">
                @Html.LabelFor(m => m.Time)
                @Html.TextBoxFor(m => m.Time, new
                    {
                        @class = "form-control",
                        id = "Time",
                        placeholder = "MM/dd HH:mm~HH:mm"
                    })
            </div>

            <div class="form-group mb-4">
                @Html.LabelFor(m => m.Section)
                @Html.TextBoxFor(m => m.Section, new { @class = "form-control", id = "Section" })
            </div>

            <div class="booking-actions">
                <button type="button" id="btnSubmit" class="btn btn-primary">登記場地</button>
                <button type="button" id="btnView" class="btn btn-secondary">查看目前已租借場地</button>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script src="~/js/booking.js"></script>
}
