@model _1132FinalProject.Models.ContactCommitteesModel
@{
    ViewData["Title"] = "_CommitteesCard";
}

<div class="card Committee-card">
    <img src="~/Images/CommitteeCard/@Model.PhotoUrl" class="Committee-photo" alt="@Model.NickName">
    <div class="card-body text-center">
        <p class="Committee-Name">@Model.NickName</p>
        <p class="Commitee-Position">@Model.Position</p>
        <p class="Commitee-Section">@Model.Section</p>
        @if (Model.IG_Account == "dancer_pizza")
        {
            <a href="https://www.instagram.com/@Model.IG_Account"
               target="_blank"
               rel="noopener noreferrer">
                @Model.IG_Account
            </a>
        }
        else
        {
            <p>@("@" + Model.IG_Account)</p>
        }
    </div>
</div>
