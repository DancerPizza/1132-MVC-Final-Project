@using System;

<!DOCTYPE html>
<html lang="zh-Hant">
<head>
	<meta charset="utf-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1.0, shrink-to-fit=no" />
	<title>@ViewData["Title"] - 1132FinalProject</title>
	<link rel="preconnect" href="https://fonts.googleapis.com" />
	<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
	<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@400;500;600;700&display=swap" rel="stylesheet" />
	<link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
	<link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
	<link rel="stylesheet" href="~/_1132FinalProject.styles.css" asp-append-version="true" />
	@await RenderSectionAsync("topCSS", required: false)
</head>
<body class="page-container">
	<header>
		<nav class="navbar navbar-expand-lg site-navbar sticky-top shadow-sm">
			<div class="container-fluid px-2 px-md-3">
				<a class="navbar-brand" asp-controller="Home" asp-action="Index">
					<img src="~/Images/YZU_Logo.png" alt="YZU Logo" />
				</a>
				<button class="navbar-toggler site-nav-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav"
						aria-controls="mainNav" aria-expanded="false" aria-label="切換導覽">
					<span class="navbar-toggler-icon"></span>
				</button>
				<div class="collapse navbar-collapse" id="mainNav">
					<ul class="navbar-nav site-nav-list ms-lg-auto">
						<li class="nav-item">
							<a class="nav-link" asp-controller="Contact" asp-action="ContactCommittee">聯絡幹部</a>
						</li>
						<li class="nav-item">
							<a class="nav-link" asp-controller="NewMembers" asp-action="NewRegister">新生登記</a>
						</li>
						<li class="nav-item">
							<a class="nav-link" asp-controller="Schedule" asp-action="Schedule">時程表</a>
						</li>
						<li class="nav-item">
							<a class="nav-link" asp-controller="Booking" asp-action="BookingSpace">場地租借</a>
						</li>
						<li class="nav-item">
							@if (Context.Session.GetString("IsAdmin") == "true")
							{
								<a class="nav-link" asp-controller="Admin" asp-action="List">新生資料表</a>
							}
							else
							{
								<a class="nav-link" asp-controller="Admin" asp-action="Login">管理員專區</a>
							}
						</li>
						@if (Context.Session.GetString("IsAdmin") == "true")
						{
							<li class="nav-item">
								<a class="nav-link" asp-controller="Admin" asp-action="Logout">登出</a>
							</li>
						}
					</ul>
				</div>
			</div>
		</nav>
	</header>
	<main role="main" class="content-wrap">
		@RenderBody()
	</main>

	<footer class="site-footer">
		<div class="container text-end px-3">
			<span class="footer-clock"><time id="clock"></time></span>
		</div>
	</footer>

	<script src="~/lib/jquery/dist/jquery.min.js"></script>
	<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
	<script src="~/js/site.js" asp-append-version="true"></script>
	<script>
		function updateTime() {
			var now = new Date();
			var timeString = now.toLocaleTimeString('zh-TW', {
				hour12: true,
				hour: '2-digit',
				minute: '2-digit',
				second: '2-digit'
			});
			var clockElement = document.getElementById("clock");
			if (clockElement) {
				clockElement.textContent = timeString;
			}
		}
		document.addEventListener('DOMContentLoaded', updateTime);
		setInterval(updateTime, 1000);
	</script>
	@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
