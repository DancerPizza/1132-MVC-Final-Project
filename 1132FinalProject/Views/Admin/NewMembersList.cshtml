@using X.PagedList
@using X.PagedList.Mvc.Core
@model IPagedList<_1132FinalProject.Models.NewMembersModel>

@{
    ViewData["Title"] = "NewMembersList";
}
@if (TempData["UpdateSuccess"] != null)
{
    <script>
        alert('@Html.Raw(TempData["UpdateSuccess"] as string)');
    </script>
}

<div class="admin-list-page page-section">
    <h1 class="page-title-wheat">新生資料表</h1>

    <div class="admin-table-wrap">
        <table class="table text-center admin-table">
            <thead>
                <tr>
                    <th>@Html.DisplayName("姓名")</th>
                    <th>@Html.DisplayName("綽號")</th>
                    <th>@Html.DisplayName("系所")</th>
                    <th>@Html.DisplayName("舞風組別")</th>
                    <th>@Html.DisplayName("IG帳號")</th>
                    <th>@Html.DisplayName("註冊時間")</th>
                    <th>操作</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@Html.DisplayFor(modelItem => item.Name)</td>
                        <td>@Html.DisplayFor(modelItem => item.NickName)</td>
                        <td>@Html.DisplayFor(modelItem => item.Department)</td>
                        <td>@Html.DisplayFor(modelItem => item.Section)</td>
                        <td>@Html.DisplayFor(modelItem => item.IG_Account)</td>
                        <td>@Html.DisplayFor(modelItem => item.RegisteredAt)</td>
                        <td>
                            <a asp-action="Details" asp-route-id="@item.StuId" class="btn btn-success">詳細</a>
                            <a asp-action="Edit" asp-route-id="@item.StuId" class="btn btn-warning">編輯</a>
                            <a asp-action="Delete" asp-route-id="@item.StuId" class="btn btn-danger">刪除</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="d-flex justify-content-center pagination-wrap">
        @Html.PagedListPager(Model, page => Url.Action("List", new { page }))
    </div>
</div>
