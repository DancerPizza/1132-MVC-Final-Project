@model _1132FinalProject.Models.NewMembersModel

@{
    ViewData["Title"] = "Details";
}

<div class="admin-detail-page page-section">
    <h1 class="page-title-wheat">詳細資料</h1>
    <hr class="border-light" />
    <table class="Details_Members">
        <tr>
            <th>@Html.DisplayNameFor(m => m.StuId)</th>
            <td>@Html.DisplayFor(m => m.StuId)</td>
        </tr>
        <tr>
            <th>@Html.DisplayNameFor(m => m.Name)</th>
            <td>@Html.DisplayFor(m => m.Name)</td>
        </tr>
        <tr>
            <th>@Html.DisplayNameFor(m => m.NickName)</th>
            <td>@Html.DisplayFor(m => m.NickName)</td>
        </tr>
        <tr>
            <th>@Html.DisplayNameFor(m => m.Department)</th>
            <td>@Html.DisplayFor(m => m.Department)</td>
        </tr>
        <tr>
            <th>@Html.DisplayNameFor(m => m.IG_Account)</th>
            <td>@Html.DisplayFor(m => m.IG_Account)</td>
        </tr>
    </table>
</div>

<div class="d-flex flex-wrap justify-content-center gap-2 pb-4">
    <a asp-action="Edit" asp-route-id="@Model.StuId" class="btn btn-warning fw-bold">編輯</a>
    <a asp-action="Delete" asp-route-id="@Model.StuId" class="btn btn-danger fw-bold">刪除</a>
    <a asp-action="List" class="btn btn-secondary fw-bold">返回清單</a>
</div>
