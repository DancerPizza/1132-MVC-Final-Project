@{
    ViewData["Title"] = "管理員登入";
}

<div class="login-page">
    <div class="Login_card">
        <h3 class="mb-4">管理員登入</h3>

        @using (Html.BeginForm("Login", "Admin", FormMethod.Post))
        {
            @Html.AntiForgeryToken()

            @if (ViewData.ModelState.Count > 0 && !ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger" role="alert">
                    @Html.ValidationSummary(false, "", new { @class = "mb-0" })
                </div>
            }

            <div class="text-center mb-4">
                <input name="username"
                       id="username"
                       type="text"
                       class="Login_textbox"
                       placeholder="請輸入帳號(1121768)"
                       required />
            </div>

            <div class="text-center mb-4">
                <input name="password"
                       id="password"
                       type="password"
                       class="Login_textbox"
                       placeholder="請輸入密碼(0011)"
                       required />
            </div>
            <div class="mb-3">
                <button type="submit" class="Login_button">登入</button>
            </div>
        }

        <div class="text-center mt-3">
            <small class="text-muted">請使用給定帳密登入</small>
        </div>
    </div>
</div>
