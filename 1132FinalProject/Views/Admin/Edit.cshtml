@model _1132FinalProject.Models.NewMembersModel

@{
    ViewData["Title"] = "Edit";
}

<div class="admin-form-page d-flex justify-content-center">
    <div class="admin-form-card">
        <h2 class="page-title-wheat text-center mb-4">編輯資料</h2>
        <form asp-action="Edit"
              asp-controller="Admin"
              asp-route-id="@Model.StuId"
              method="post">
            @Html.AntiForgeryToken()

            <input asp-for="StuId" type="hidden" />

            <div class="text-center text-wheat mb-3">
                <label class="fw-bold fs-5">學號</label>
                <p class="form-control-plaintext text-wheat fs-5">@Model.StuId</p>
            </div>

            <div class="Register_textbox text-center">
                <label asp-for="Name" class="control-label text-white"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="Register_textbox text-center">
                <label asp-for="NickName" class="control-label text-white"></label>
                <input asp-for="NickName" class="form-control" />
                <span asp-validation-for="NickName" class="text-danger"></span>
            </div>

            <div class="Register_textbox text-center">
                <label asp-for="Department" class="control-label text-white"></label>
                <input asp-for="Department" class="form-control" />
                <span asp-validation-for="Department" class="text-danger"></span>
            </div>

            <div class="Register_textbox text-center">
                <label asp-for="Section" class="control-label text-white"></label>
                <input asp-for="Section" class="form-control" />
                <span asp-validation-for="Section" class="text-danger"></span>
            </div>

            <div class="Register_textbox text-center">
                <label asp-for="IG_Account" class="control-label text-white"></label>
                <input asp-for="IG_Account" class="form-control" />
                <span asp-validation-for="IG_Account" class="text-danger"></span>
            </div>

            <div class="text-center mt-3">
                <button type="submit" class="btn btn-warning fw-bold w-100" style="max-width:250px">更新</button>
            </div>
        </form>

        <div class="d-flex flex-column align-items-center gap-2 mt-3">
            <a asp-action="Details" asp-route-id="@Model.StuId" class="btn btn-success fw-bold w-100" style="max-width:250px">詳細資料</a>
            <a asp-action="List" class="btn btn-secondary fw-bold w-100" style="max-width:250px">返回清單</a>
        </div>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
